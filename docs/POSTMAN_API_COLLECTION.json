{
    "info": {
      "name": "Smart Persona API",
      "description": "API Documentation for Smart Persona Platform - สามารถนำเข้าลงใน Postman ได้ทันที",
      "version": "1.0.0",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
      "type": "bearer",
      "bearer": [
        {
          "key": "token",
          "value": "{{auth_token}}",
          "type": "string"
        }
      ]
    },
    "item": [
      {
        "name": "🔐 Authentication",
        "item": [
          {
            "name": "Sign Up",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\"\n}"
              },
              "url": {
                "raw": "{{BASE_URL}}/auth/sign-up",
                "host": [
                  "{{BASE_URL}}"
                ],
                "path": [
                  "auth",
                  "sign-up"
                ]
              },
              "description": "ลงทะเบียนผู้ใช้ใหม่\n\nStatus Codes:\n- 200: Sign up successful\n- 400: Invalid email/password\n- 409: Email already exists"
            }
          },
          {
            "name": "Login",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\"\n}"
              },
              "url": {
                "raw": "{{BASE_URL}}/auth/login",
                "host": [
                  "{{BASE_URL}}"
                ],
                "path": [
                  "auth",
                  "login"
                ]
              },
              "description": "เข้าสู่ระบบ\n\nStatus Codes:\n- 200: Login successful (returns auth token)\n- 401: Invalid credentials\n- 404: User not found"
            }
          }
        ]
      },
      {
        "name": "📝 Community Posts",
        "item": [
          {
            "name": "Create Post",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "Authorization",
                  "value": "Bearer {{auth_token}}"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"userId\": \"user-uuid-here\",\n  \"title\": \"My First Post\",\n  \"content\": \"This is the content of my post\",\n  \"postType\": \"Text\",\n  \"personaId\": \"persona-uuid\",\n  \"tags\": [\"javascript\", \"web development\"],\n  \"imageUrl\": \"https://example.com/image.jpg\"\n}"
              },
              "url": {
                "raw": "{{BASE_URL}}/api/community/posts",
                "host": [
                  "{{BASE_URL}}"
                ],
                "path": [
                  "api",
                  "community",
                  "posts"
                ]
              },
              "description": "สร้างโพสต์ใหม่ (จะอยู่ในสถานะ pending รอการอนุมัติ)\n\nStatus Codes:\n- 201: Post created successfully\n- 401: Unauthorized (token required)\n- 403: Forbidden (userId mismatch)\n- 500: Server error"
            }
          },
          {
            "name": "Delete Post",
            "request": {
              "method": "DELETE",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{auth_token}}"
                }
              ],
              "url": {
                "raw": "{{BASE_URL}}/api/community/posts/:id",
                "host": [
                  "{{BASE_URL}}"
                ],
                "path": [
                  "api",
                  "community",
                  "posts",
                  ":id"
                ],
                "variable": [
                  {
                    "key": "id",
                    "value": "post-uuid-here",
                    "description": "Post ID to delete"
                  }
                ]
              },
              "description": "ลบโพสต์ (เฉพาะเจ้าของโพสต์)\n\nStatus Codes:\n- 200: Post deleted successfully\n- 401: Unauthorized\n- 403: Forbidden (not the post owner)\n- 404: Post not found\n- 500: Server error"
            }
          },
          {
            "name": "Get Post by ID",
            "request": {
              "method": "GET",
              "header": [],
              "url": {
                "raw": "{{BASE_URL}}/api/community/posts/:id",
                "host": [
                  "{{BASE_URL}}"
                ],
                "path": [
                  "api",
                  "community",
                  "posts",
                  ":id"
                ],
                "variable": [
                  {
                    "key": "id",
                    "value": "post-uuid-here",
                    "description": "Post ID"
                  }
                ]
              },
              "description": "ดึงข้อมูลโพสต์แบบละเอียด\n\nStatus Codes:\n- 200: Success\n- 404: Post not found"
            }
          }
        ]
      },
