                  "admin",
                  "posts",
                  ":id",
                  "moderate"
                ],
                "variable": [
                  {
                    "key": "id",
                    "value": "post-uuid-here"
                  }
                ]
              },
              "description": "ปฏิเสธโพสต์ (ต้องระบุเหตุผล)\n\nStatus Codes:\n- 200: Post rejected\n- 400: Missing rejection reason\n- 401: Unauthorized\n- 403: Forbidden (admin only)"
            }
          }
        ]
